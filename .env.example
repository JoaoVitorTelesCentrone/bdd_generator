# ============================================================
# BDD Generator — Backend (FastAPI)
# ============================================================
# Copie para .env e preencha. NUNCA commite o .env real.
# No Railway: configure cada variável em Settings > Variables
# ============================================================

# ── LLMs ─────────────────────────────────────────────────────
# Gemini (padrão — barato e rápido)
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq (modelos Llama/DeepSeek — free tier)
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=

# Anthropic / Claude (opcional)
# Obtenha em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── CORS ─────────────────────────────────────────────────────
# URL do frontend em produção (ex: https://seuapp.vercel.app)
FRONTEND_URL=

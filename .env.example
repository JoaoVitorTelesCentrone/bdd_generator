# ============================================================
# BDD Generator — Variáveis de ambiente (Backend Python)
# ============================================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite .env no git.
# ============================================================

# ── APIs dos modelos de linguagem ────────────────────────────
# Gemini (modelos: flash, pro, flash-lite)
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=COLOQUE_AQUI

# Claude/Anthropic (modelos: sonnet, opus, haiku)
# Obtenha em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=COLOQUE_AQUI

# ── Frontend (para CORS em produção) ─────────────────────────
# URL pública do frontend Next.js
# Deixe comentado em desenvolvimento local
# FRONTEND_URL=https://seudominio.com

# BIST configuration
# Copy to .bist.yml at your project root and customise.

model: sonnet        # LLM for BDD generation: sonnet | opus | haiku | flash | pro
threshold: 7.0       # Minimum quality score 0–10
max_attempts: 5      # Max refinement iterations before giving up

executor:
  headless: true           # true = no browser window
  timeout_ms: 10000        # Per-step timeout in milliseconds
  self_heal: true          # Ask Claude to suggest selectors on failure
  screenshots_dir: bist_output/screenshots
  videos_dir: bist_output/videos

reports:
  output_dir: bist_output/reports
  formats: [html, json]    # html | json | github | all

retry:
  max_attempts: 3
  backoff_seconds: [2, 5, 10]
  on: [selector_timeout, network_error]

notifications:
  # Set env vars BIST_SLACK_WEBHOOK / BIST_DISCORD_WEBHOOK, or hard-code here:
  # slack_webhook: https://hooks.slack.com/services/...
  # discord_webhook: https://discord.com/api/webhooks/...

visual:
  baselines_dir: bist_output/baselines
  diffs_dir: bist_output/visual_diffs
  threshold: 0.01   # max allowed changed-pixel ratio (1%)

parallel: 1         # max concurrent browser instances for execute / full

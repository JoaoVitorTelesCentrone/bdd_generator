# ============================================================
# BDD Generator — Variáveis de ambiente (Frontend Next.js)
# ============================================================
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite .env.local no git.
# ============================================================

# ── Backend URL ──────────────────────────────────────────────
# Em dev: deixe comentado (usa http://localhost:8000/api por padrão)
# Em produção: URL pública do backend FastAPI
# NEXT_PUBLIC_API_URL=https://api.seudominio.com/api

# ── Supabase ─────────────────────────────────────────────────
# Encontre em: https://supabase.com/dashboard/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Chave de serviço (somente servidor — NUNCA exponha no frontend)
# Encontre em: Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Stripe ───────────────────────────────────────────────────
# Encontre em: https://dashboard.stripe.com/apikeys
# Use pk_test_* / sk_test_* para testes, pk_live_* / sk_live_* para produção
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_COLOQUE_AQUI
STRIPE_SECRET_KEY=sk_test_COLOQUE_AQUI

# Segredo do webhook — gere em: https://dashboard.stripe.com/webhooks
# Eventos necessários: checkout.session.completed, customer.subscription.updated,
#                      customer.subscription.deleted, invoice.payment_failed
# URL do endpoint: https://seudominio.com/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_COLOQUE_AQUI

# Price ID do plano Pro — Stripe Dashboard > Products > Pro > Price
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_COLOQUE_AQUI
